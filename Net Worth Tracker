#!/usr/bin/env python3
"""
Net Worth Tracker
------------------
A dependency-free CLI tool for tracking personal net worth over time.

Data model
==========
All data lives in a single JSON file (default: net_worth_data.json):

{
  "accounts": {
    "Checking":    {"type": "asset",     "balance": 5000.0, "category": "Cash"},
    "Credit Card": {"type": "liability", "balance": 1200.0, "category": "Debt"}
  },
  "history": [
    {"date": "2026-07-05", "balances": {"Checking": 5000.0, "Credit Card": 1200.0}}
  ],
  "goal": 100000.0
}

- "asset" balances add to net worth.
- "liability" balances are stored as positive numbers but subtracted from net worth.
- "category" groups accounts for the allocation breakdown (e.g. Cash, Investments,
  Retirement, Real Estate, Debt). Defaults to "Other" if not given.
- "history" is a list of snapshots taken over time so you can chart progress.
- "goal" is an optional target net worth. When set, 'report' shows progress
  toward it and a projected date based on your recent trend.

Usage
=====
  python net_worth_tracker.py add-account "Checking" asset 5000 --category Cash
  python net_worth_tracker.py add-account "Credit Card" liability 1200 --category Debt
  python net_worth_tracker.py update "Checking" 5250
  python net_worth_tracker.py snapshot
  python net_worth_tracker.py set-goal 100000
  python net_worth_tracker.py report
  python net_worth_tracker.py allocation
  python net_worth_tracker.py history
  python net_worth_tracker.py chart
  python net_worth_tracker.py chart --type allocation
  python net_worth_tracker.py remove-account "Old 401k"

Run `python net_worth_tracker.py -h` for full help.
"""

import argparse
import csv
import json
import os
import sys
from datetime import date, datetime

DEFAULT_DATA_FILE = "net_worth_data.json"


# --------------------------------------------------------------------------
# Data helpers
# --------------------------------------------------------------------------

def load_data(path):
    if not os.path.exists(path):
        return {"accounts": {}, "history": [], "goal": None}
    with open(path, "r") as f:
        try:
            data = json.load(f)
        except json.JSONDecodeError:
            print(f"Error: '{path}' is not valid JSON. Aborting.", file=sys.stderr)
            sys.exit(1)
    data.setdefault("accounts", {})
    data.setdefault("history", [])
    data.setdefault("goal", None)
    for info in data["accounts"].values():
        info.setdefault("category", "Other")
    return data


def save_data(path, data):
    with open(path, "w") as f:
        json.dump(data, f, indent=2, sort_keys=False)


def compute_net_worth(balances, accounts):
    """balances: dict of account -> raw stored balance (liabilities positive)."""
    total = 0.0
    for name, bal in balances.items():
        acc_type = accounts.get(name, {}).get("type", "asset")
        total += bal if acc_type == "asset" else -bal
    return total


def fmt_money(x):
    sign = "-" if x < 0 else ""
    return f"{sign}${abs(x):,.2f}"


def estimate_goal_projection(data):
    """
    Returns a dict describing progress toward data['goal'], or None if no
    goal is set. Uses a simple least-squares linear fit over snapshot
    history to project a date, when there's enough history to do so.
    """
    goal = data.get("goal")
    if goal is None:
        return None

    accounts = data["accounts"]
    current_balances = {name: info["balance"] for name, info in accounts.items()}
    current_net_worth = compute_net_worth(current_balances, accounts)

    result = {
        "goal": goal,
        "current": current_net_worth,
        "pct": None,
        "remaining": goal - current_net_worth,
        "projection": None,
    }

    if goal > 0:
        result["pct"] = max(0.0, min(1.0, current_net_worth / goal))
    if current_net_worth >= goal:
        result["projection"] = "reached"
        return result

    history = data.get("history", [])
    if len(history) < 2:
        result["projection"] = "insufficient_history"
        return result

    # Simple linear regression: x = days since first snapshot, y = net worth.
    points = []
    for h in history:
        try:
            d = datetime.strptime(h["date"], "%Y-%m-%d")
        except ValueError:
            continue
        nw = compute_net_worth(h["balances"], accounts)
        points.append((d, nw))
    points.sort(key=lambda p: p[0])

    if len(points) < 2:
        result["projection"] = "insufficient_history"
        return result

    x0 = points[0][0]
    xs = [(d - x0).days for d, _ in points]
    ys = [nw for _, nw in points]
    n = len(xs)
    mean_x = sum(xs) / n
    mean_y = sum(ys) / n
    denom = sum((x - mean_x) ** 2 for x in xs)
    if denom == 0:
        result["projection"] = "insufficient_history"
        return result
    slope = sum((x - mean_x) * (y - mean_y) for x, y in zip(xs, ys)) / denom  # $/day

    if slope <= 0:
        result["projection"] = "not_trending"
        return result

    days_needed = (goal - current_net_worth) / slope
    projected_date = date.today().fromordinal(date.today().toordinal() + int(round(days_needed)))
    result["projection"] = "on_track"
    result["projected_date"] = projected_date.isoformat()
    result["dollars_per_day"] = slope
    return result


def compute_allocation(accounts, acc_type="asset"):
    """Returns [(category, total_balance), ...] sorted descending, for the given account type."""
    totals = {}
    for info in accounts.values():
        if info["type"] != acc_type:
            continue
        cat = info.get("category", "Other")
        totals[cat] = totals.get(cat, 0.0) + info["balance"]
    return sorted(totals.items(), key=lambda kv: kv[1], reverse=True)


# --------------------------------------------------------------------------
# Commands
# --------------------------------------------------------------------------

def cmd_add_account(args, data, path):
    name = args.name
    if name in data["accounts"]:
        print(f"Account '{name}' already exists. Use 'update' to change its balance "
              f"or 'remove-account' to delete it first.")
        sys.exit(1)
    if args.type not in ("asset", "liability"):
        print("Account type must be 'asset' or 'liability'.")
        sys.exit(1)
    category = args.category or "Other"
    data["accounts"][name] = {"type": args.type, "balance": args.balance, "category": category}
    save_data(path, data)
    print(f"Added {args.type} account '{name}' ({category}) with balance {fmt_money(args.balance)}.")


def cmd_remove_account(args, data, path):
    if args.name not in data["accounts"]:
        print(f"No such account: '{args.name}'")
        sys.exit(1)
    del data["accounts"][args.name]
    save_data(path, data)
    print(f"Removed account '{args.name}'. (Past history entries are kept as-is.)")


def cmd_update(args, data, path):
    if args.name not in data["accounts"]:
        print(f"No such account: '{args.name}'. Add it first with 'add-account'.")
        sys.exit(1)
    data["accounts"][args.name]["balance"] = args.balance
    save_data(path, data)
    print(f"Updated '{args.name}' to {fmt_money(args.balance)}.")


def cmd_list(args, data, path):
    if not data["accounts"]:
        print("No accounts yet. Add one with 'add-account'.")
        return
    print(f"{'Account':<25}{'Type':<12}{'Category':<15}{'Balance':>15}")
    print("-" * 67)
    for name, info in data["accounts"].items():
        print(f"{name:<25}{info['type']:<12}{info.get('category', 'Other'):<15}{fmt_money(info['balance']):>15}")


def cmd_snapshot(args, data, path):
    if not data["accounts"]:
        print("No accounts to snapshot. Add one with 'add-account' first.")
        sys.exit(1)
    snap_date = args.date or date.today().isoformat()
    balances = {name: info["balance"] for name, info in data["accounts"].items()}

    already_exists = any(h["date"] == snap_date for h in data["history"])
    if already_exists and not args.force:
        print(f"A snapshot for {snap_date} already exists. Re-run with --force to overwrite it.")
        sys.exit(1)

    # Replace an existing snapshot for the same date, if present.
    data["history"] = [h for h in data["history"] if h["date"] != snap_date]
    data["history"].append({"date": snap_date, "balances": balances})
    data["history"].sort(key=lambda h: h["date"])

    save_data(path, data)
    net_worth = compute_net_worth(balances, data["accounts"])
    verb = "replaced" if already_exists else "recorded"
    print(f"Snapshot {verb} for {snap_date}. Net worth: {fmt_money(net_worth)}")


def cmd_set_goal(args, data, path):
    if args.amount <= 0:
        print("Goal amount must be positive.")
        sys.exit(1)
    data["goal"] = args.amount
    save_data(path, data)
    print(f"Goal set to {fmt_money(args.amount)}. Run 'report' to see your progress.")


def cmd_allocation(args, data, path):
    accounts = data["accounts"]
    if not accounts:
        print("No accounts yet. Add one with 'add-account'.")
        return

    def print_breakdown(title, acc_type):
        alloc = compute_allocation(accounts, acc_type)
        total = sum(t for _, t in alloc)
        print(title)
        if not alloc:
            print("  (none)")
            return
        bar_width = 24
        for cat, amount in alloc:
            pct = (amount / total) if total else 0
            filled = int(round(pct * bar_width))
            bar = "#" * filled + "-" * (bar_width - filled)
            print(f"  {cat:<18}[{bar}] {fmt_money(amount):>13} ({pct * 100:.1f}%)")
        print(f"  {'Total':<18}{' ' * (bar_width + 2)}{fmt_money(total):>13}")

    print_breakdown("ASSET ALLOCATION", "asset")
    print()
    print_breakdown("LIABILITY BREAKDOWN", "liability")


def cmd_report(args, data, path):
    if not data["accounts"]:
        print("No accounts yet. Add one with 'add-account'.")
        return

    assets = {n: i["balance"] for n, i in data["accounts"].items() if i["type"] == "asset"}
    liabilities = {n: i["balance"] for n, i in data["accounts"].items() if i["type"] == "liability"}

    total_assets = sum(assets.values())
    total_liabilities = sum(liabilities.values())
    net_worth = total_assets - total_liabilities

    print("ASSETS")
    for n, b in assets.items():
        pct = f" ({b / total_assets * 100:.1f}%)" if total_assets else ""
        print(f"  {n:<25}{fmt_money(b):>15}{pct:>9}")
    print(f"  {'Total assets':<25}{fmt_money(total_assets):>15}")

    asset_alloc = compute_allocation(data["accounts"], "asset")
    if len(asset_alloc) > 1:
        print("\n  By category:")
        for cat, total in asset_alloc:
            pct = (total / total_assets * 100) if total_assets else 0
            print(f"    {cat:<23}{fmt_money(total):>15} ({pct:.1f}%)")

    print("\nLIABILITIES")
    for n, b in liabilities.items():
        print(f"  {n:<25}{fmt_money(b):>15}")
    print(f"  {'Total liabilities':<25}{fmt_money(total_liabilities):>15}")

    print("\n" + "=" * 40)
    print(f"  {'NET WORTH':<25}{fmt_money(net_worth):>15}")
    print("=" * 40)

    if data["history"]:
        first = data["history"][0]
        first_net = compute_net_worth(first["balances"], data["accounts"])
        change = net_worth - first_net
        print(f"\nChange since first snapshot ({first['date']}): {fmt_money(change)}")

    goal_info = estimate_goal_projection(data)
    if goal_info:
        print("\nGOAL")
        bar_width = 30
        filled = int(round((goal_info["pct"] or 0) * bar_width))
        bar = "#" * filled + "-" * (bar_width - filled)
        pct_display = f"{(goal_info['pct'] or 0) * 100:.1f}%"
        print(f"  [{bar}] {pct_display}")
        print(f"  {fmt_money(goal_info['current'])} of {fmt_money(goal_info['goal'])}")

        proj = goal_info["projection"]
        if proj == "reached":
            print("  Goal reached! 🎉")
        elif proj == "insufficient_history":
            print(f"  {fmt_money(goal_info['remaining'])} remaining. "
                  f"Record at least 2 snapshots to get a projected date.")
        elif proj == "not_trending":
            print(f"  {fmt_money(goal_info['remaining'])} remaining. "
                  f"Your recent trend is flat or declining, so a projection isn't available.")
        elif proj == "on_track":
            print(f"  {fmt_money(goal_info['remaining'])} remaining. "
                  f"At your current trend (~{fmt_money(goal_info['dollars_per_day'])}/day), "
                  f"projected to reach your goal around {goal_info['projected_date']}.")


def cmd_history(args, data, path):
    if not data["history"]:
        print("No snapshots yet. Use 'snapshot' to record one.")
        return
    print(f"{'Date':<14}{'Net Worth':>15}")
    print("-" * 29)
    for h in data["history"]:
        net_worth = compute_net_worth(h["balances"], data["accounts"])
        print(f"{h['date']:<14}{fmt_money(net_worth):>15}")


def cmd_chart(args, data, path):
    try:
        import matplotlib.pyplot as plt
    except ImportError:
        print("matplotlib is not installed. Install it with:\n  pip install matplotlib")
        sys.exit(1)

    if args.type == "allocation":
        alloc = compute_allocation(data["accounts"], "asset")
        if not alloc:
            print("No asset accounts yet. Add one with 'add-account' before charting allocation.")
            return
        labels = [cat for cat, _ in alloc]
        values = [amount for _, amount in alloc]

        plt.figure(figsize=(7, 7))
        plt.pie(values, labels=labels, autopct="%1.1f%%", startangle=90)
        plt.title("Asset Allocation by Category")
        plt.tight_layout()

        out_path = args.output or "net_worth_allocation.png"
        plt.savefig(out_path, dpi=150)
        print(f"Allocation chart saved to '{out_path}'.")
        return

    if not data["history"]:
        print("No snapshots yet. Use 'snapshot' to record one before charting.")
        return

    dates = [h["date"] for h in data["history"]]
    values = [compute_net_worth(h["balances"], data["accounts"]) for h in data["history"]]
    parsed_dates = [datetime.strptime(d, "%Y-%m-%d") for d in dates]

    plt.figure(figsize=(10, 5))
    plt.plot(parsed_dates, values, marker="o", linewidth=2)
    plt.title("Net Worth Over Time")
    plt.xlabel("Date")
    plt.ylabel("Net Worth ($)")
    plt.grid(True, alpha=0.3)
    plt.tight_layout()

    out_path = args.output or "net_worth_chart.png"
    plt.savefig(out_path, dpi=150)
    print(f"Chart saved to '{out_path}'.")


def cmd_export_csv(args, data, path):
    """Writes one row per snapshot, one column per account. Column headers encode
    each account's type and category as 'Name (type/category)' so 'import-csv'
    can recover the full schema, not just raw numbers. Compatible with the
    web UI's Export/Import CSV feature."""
    accounts = data["accounts"]
    account_names = list(accounts.keys())
    header = ["Date"] + [
        f"{name} ({accounts[name]['type']}/{accounts[name].get('category', 'Other')})"
        for name in account_names
    ] + ["Net Worth"]

    history = sorted(data["history"], key=lambda h: h["date"])
    out_path = args.output or "net_worth_history.csv"

    with open(out_path, "w", newline="") as f:
        writer = csv.writer(f)
        writer.writerow(header)
        if history:
            for h in history:
                row = [h["date"]] + [h["balances"].get(name, "") for name in account_names]
                row.append(compute_net_worth(h["balances"], accounts))
                writer.writerow(row)
        elif account_names:
            row = ["Current"] + [accounts[name]["balance"] for name in account_names]
            row.append(compute_net_worth({n: accounts[n]["balance"] for n in account_names}, accounts))
            writer.writerow(row)

    print(f"CSV exported to '{out_path}'.")


def cmd_import_csv(args, data, path):
    import re

    with open(args.file_path, "r", newline="") as f:
        rows = list(csv.reader(f))

    if len(rows) < 2:
        print("That CSV has no data rows.")
        sys.exit(1)

    header = rows[0]
    last_is_net_worth = header[-1].strip().lower() == "net worth"
    acc_end = len(header) - 1 if last_is_net_worth else len(header)

    account_defs = []  # (col_index, name, type, category)
    for i in range(1, acc_end):
        raw = header[i]
        m = re.match(r"^(.*)\s\(([^/()]+)/([^()]+)\)\s*$", raw)
        if m:
            name, acc_type, category = m.group(1).strip(), m.group(2).strip().lower(), m.group(3).strip()
            acc_type = "liability" if acc_type == "liability" else "asset"
        else:
            name, acc_type, category = raw.strip(), "asset", "Other"
        if name:
            account_defs.append((i, name, acc_type, category))

    if not account_defs:
        print("No account columns found in that CSV.")
        sys.exit(1)

    new_accounts = {}
    new_history = []

    for row in rows[1:]:
        if not row or not row[0].strip():
            continue
        date_val = row[0].strip()
        balances = {}
        for col, name, acc_type, category in account_defs:
            if col >= len(row) or row[col] == "":
                continue
            cleaned = re.sub(r"[^0-9.\-]", "", row[col])
            if not cleaned:
                continue
            try:
                num = float(cleaned)
            except ValueError:
                continue
            balances[name] = num
            new_accounts[name] = {"type": acc_type, "balance": num, "category": category}
        if re.match(r"^\d{4}-\d{2}-\d{2}$", date_val):
            new_history.append({"date": date_val, "balances": balances})

    new_history.sort(key=lambda h: h["date"])
    data["accounts"] = new_accounts
    data["history"] = new_history
    save_data(path, data)
    print(f"Imported {len(new_accounts)} account(s) and {len(new_history)} snapshot(s) from '{args.file_path}'.")


# --------------------------------------------------------------------------
# Argument parsing
# --------------------------------------------------------------------------

def build_parser():
    parser = argparse.ArgumentParser(
        description="Track your personal net worth over time from the command line.",
    )
    parser.add_argument(
        "--file", default=DEFAULT_DATA_FILE,
        help=f"Path to the JSON data file (default: {DEFAULT_DATA_FILE})"
    )
    sub = parser.add_subparsers(dest="command", required=True)

    p = sub.add_parser("add-account", help="Add a new asset or liability account")
    p.add_argument("name", help="Account name, e.g. 'Checking'")
    p.add_argument("type", choices=["asset", "liability"], help="Account type")
    p.add_argument("balance", type=float, help="Starting balance (always positive)")
    p.add_argument(
        "--category", default="Other",
        help="Group for the allocation breakdown, e.g. Cash, Investments, Retirement, "
             "Real Estate, Debt (default: Other)"
    )
    p.set_defaults(func=cmd_add_account)

    p = sub.add_parser("remove-account", help="Remove an account")
    p.add_argument("name", help="Account name to remove")
    p.set_defaults(func=cmd_remove_account)

    p = sub.add_parser("update", help="Update an account's current balance")
    p.add_argument("name", help="Account name")
    p.add_argument("balance", type=float, help="New balance (always positive)")
    p.set_defaults(func=cmd_update)

    p = sub.add_parser("list", help="List all accounts and current balances")
    p.set_defaults(func=cmd_list)

    p = sub.add_parser("snapshot", help="Record a dated net worth snapshot from current balances")
    p.add_argument("--date", help="Date for the snapshot, YYYY-MM-DD (default: today)")
    p.add_argument("--force", action="store_true", help="Overwrite an existing snapshot for that date without asking")
    p.set_defaults(func=cmd_snapshot)

    p = sub.add_parser("report", help="Show current net worth broken down by account")
    p.set_defaults(func=cmd_report)

    p = sub.add_parser("allocation", help="Show asset/liability breakdown by category")
    p.set_defaults(func=cmd_allocation)

    p = sub.add_parser("set-goal", help="Set a target net worth to track progress toward")
    p.add_argument("amount", type=float, help="Target net worth amount")
    p.set_defaults(func=cmd_set_goal)

    p = sub.add_parser("history", help="Show net worth for every recorded snapshot")
    p.set_defaults(func=cmd_history)

    p = sub.add_parser("chart", help="Save a PNG chart (requires matplotlib)")
    p.add_argument(
        "--type", choices=["networth", "allocation"], default="networth",
        help="'networth' (default): net worth line chart over time. "
             "'allocation': asset allocation pie chart by category."
    )
    p.add_argument("--output", help="Output PNG path (default depends on --type)")
    p.set_defaults(func=cmd_chart)

    p = sub.add_parser("export-csv", help="Export snapshot history to CSV (one row per snapshot)")
    p.add_argument("--output", help="Output CSV path (default: net_worth_history.csv)")
    p.set_defaults(func=cmd_export_csv)

    p = sub.add_parser("import-csv", help="Import accounts and history from a CSV file (replaces current data)")
    p.add_argument("file_path", help="Path to the CSV file to import")
    p.set_defaults(func=cmd_import_csv)

    return parser


def main():
    parser = build_parser()
    args = parser.parse_args()
    data = load_data(args.file)
    args.func(args, data, args.file)


if __name__ == "__main__":
    main()
