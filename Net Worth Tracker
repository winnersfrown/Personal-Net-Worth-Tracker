#!/usr/bin/env python3
"""
Net Worth Tracker
------------------
A dependency-free CLI tool for tracking personal net worth over time.

Data model
==========
All data lives in a single JSON file (default: net_worth_data.json):

{
  "accounts": {
    "Checking":    {"type": "asset",     "balance": 5000.0},
    "Credit Card": {"type": "liability", "balance": 1200.0}
  },
  "history": [
    {"date": "2026-07-05", "balances": {"Checking": 5000.0, "Credit Card": 1200.0}}
  ]
}

- "asset" balances add to net worth.
- "liability" balances are stored as positive numbers but subtracted from net worth.
- "history" is a list of snapshots taken over time so you can chart progress.

Usage
=====
  python net_worth_tracker.py add-account "Checking" asset 5000
  python net_worth_tracker.py add-account "Credit Card" liability 1200
  python net_worth_tracker.py update "Checking" 5250
  python net_worth_tracker.py snapshot
  python net_worth_tracker.py report
  python net_worth_tracker.py history
  python net_worth_tracker.py chart
  python net_worth_tracker.py remove-account "Old 401k"

Run `python net_worth_tracker.py -h` for full help.
"""

import argparse
import json
import os
import sys
from datetime import date, datetime

DEFAULT_DATA_FILE = "net_worth_data.json"


# --------------------------------------------------------------------------
# Data helpers
# --------------------------------------------------------------------------

def load_data(path):
    if not os.path.exists(path):
        return {"accounts": {}, "history": []}
    with open(path, "r") as f:
        try:
            return json.load(f)
        except json.JSONDecodeError:
            print(f"Error: '{path}' is not valid JSON. Aborting.", file=sys.stderr)
            sys.exit(1)


def save_data(path, data):
    with open(path, "w") as f:
        json.dump(data, f, indent=2, sort_keys=False)


def compute_net_worth(balances, accounts):
    """balances: dict of account -> raw stored balance (liabilities positive)."""
    total = 0.0
    for name, bal in balances.items():
        acc_type = accounts.get(name, {}).get("type", "asset")
        total += bal if acc_type == "asset" else -bal
    return total


def fmt_money(x):
    sign = "-" if x < 0 else ""
    return f"{sign}${abs(x):,.2f}"


# --------------------------------------------------------------------------
# Commands
# --------------------------------------------------------------------------

def cmd_add_account(args, data, path):
    name = args.name
    if name in data["accounts"]:
        print(f"Account '{name}' already exists. Use 'update' to change its balance "
              f"or 'remove-account' to delete it first.")
        sys.exit(1)
    if args.type not in ("asset", "liability"):
        print("Account type must be 'asset' or 'liability'.")
        sys.exit(1)
    data["accounts"][name] = {"type": args.type, "balance": args.balance}
    save_data(path, data)
    print(f"Added {args.type} account '{name}' with balance {fmt_money(args.balance)}.")


def cmd_remove_account(args, data, path):
    if args.name not in data["accounts"]:
        print(f"No such account: '{args.name}'")
        sys.exit(1)
    del data["accounts"][args.name]
    save_data(path, data)
    print(f"Removed account '{args.name}'. (Past history entries are kept as-is.)")


def cmd_update(args, data, path):
    if args.name not in data["accounts"]:
        print(f"No such account: '{args.name}'. Add it first with 'add-account'.")
        sys.exit(1)
    data["accounts"][args.name]["balance"] = args.balance
    save_data(path, data)
    print(f"Updated '{args.name}' to {fmt_money(args.balance)}.")


def cmd_list(args, data, path):
    if not data["accounts"]:
        print("No accounts yet. Add one with 'add-account'.")
        return
    print(f"{'Account':<25}{'Type':<12}{'Balance':>15}")
    print("-" * 52)
    for name, info in data["accounts"].items():
        print(f"{name:<25}{info['type']:<12}{fmt_money(info['balance']):>15}")


def cmd_snapshot(args, data, path):
    if not data["accounts"]:
        print("No accounts to snapshot. Add one with 'add-account' first.")
        sys.exit(1)
    snap_date = args.date or date.today().isoformat()
    balances = {name: info["balance"] for name, info in data["accounts"].items()}

    # Replace an existing snapshot for the same date, if present.
    data["history"] = [h for h in data["history"] if h["date"] != snap_date]
    data["history"].append({"date": snap_date, "balances": balances})
    data["history"].sort(key=lambda h: h["date"])

    save_data(path, data)
    net_worth = compute_net_worth(balances, data["accounts"])
    print(f"Snapshot recorded for {snap_date}. Net worth: {fmt_money(net_worth)}")


def cmd_report(args, data, path):
    if not data["accounts"]:
        print("No accounts yet. Add one with 'add-account'.")
        return

    assets = {n: i["balance"] for n, i in data["accounts"].items() if i["type"] == "asset"}
    liabilities = {n: i["balance"] for n, i in data["accounts"].items() if i["type"] == "liability"}

    total_assets = sum(assets.values())
    total_liabilities = sum(liabilities.values())
    net_worth = total_assets - total_liabilities

    print("ASSETS")
    for n, b in assets.items():
        print(f"  {n:<25}{fmt_money(b):>15}")
    print(f"  {'Total assets':<25}{fmt_money(total_assets):>15}")

    print("\nLIABILITIES")
    for n, b in liabilities.items():
        print(f"  {n:<25}{fmt_money(b):>15}")
    print(f"  {'Total liabilities':<25}{fmt_money(total_liabilities):>15}")

    print("\n" + "=" * 40)
    print(f"  {'NET WORTH':<25}{fmt_money(net_worth):>15}")
    print("=" * 40)

    if data["history"]:
        first = data["history"][0]
        first_net = compute_net_worth(first["balances"], data["accounts"])
        change = net_worth - first_net
        print(f"\nChange since first snapshot ({first['date']}): {fmt_money(change)}")


def cmd_history(args, data, path):
    if not data["history"]:
        print("No snapshots yet. Use 'snapshot' to record one.")
        return
    print(f"{'Date':<14}{'Net Worth':>15}")
    print("-" * 29)
    for h in data["history"]:
        net_worth = compute_net_worth(h["balances"], data["accounts"])
        print(f"{h['date']:<14}{fmt_money(net_worth):>15}")


def cmd_chart(args, data, path):
    if not data["history"]:
        print("No snapshots yet. Use 'snapshot' to record one before charting.")
        return
    try:
        import matplotlib.pyplot as plt
    except ImportError:
        print("matplotlib is not installed. Install it with:\n  pip install matplotlib")
        sys.exit(1)

    dates = [h["date"] for h in data["history"]]
    values = [compute_net_worth(h["balances"], data["accounts"]) for h in data["history"]]
    parsed_dates = [datetime.strptime(d, "%Y-%m-%d") for d in dates]

    plt.figure(figsize=(10, 5))
    plt.plot(parsed_dates, values, marker="o", linewidth=2)
    plt.title("Net Worth Over Time")
    plt.xlabel("Date")
    plt.ylabel("Net Worth ($)")
    plt.grid(True, alpha=0.3)
    plt.tight_layout()

    out_path = args.output or "net_worth_chart.png"
    plt.savefig(out_path, dpi=150)
    print(f"Chart saved to '{out_path}'.")


# --------------------------------------------------------------------------
# Argument parsing
# --------------------------------------------------------------------------

def build_parser():
    parser = argparse.ArgumentParser(
        description="Track your personal net worth over time from the command line.",
    )
    parser.add_argument(
        "--file", default=DEFAULT_DATA_FILE,
        help=f"Path to the JSON data file (default: {DEFAULT_DATA_FILE})"
    )
    sub = parser.add_subparsers(dest="command", required=True)

    p = sub.add_parser("add-account", help="Add a new asset or liability account")
    p.add_argument("name", help="Account name, e.g. 'Checking'")
    p.add_argument("type", choices=["asset", "liability"], help="Account type")
    p.add_argument("balance", type=float, help="Starting balance (always positive)")
    p.set_defaults(func=cmd_add_account)

    p = sub.add_parser("remove-account", help="Remove an account")
    p.add_argument("name", help="Account name to remove")
    p.set_defaults(func=cmd_remove_account)

    p = sub.add_parser("update", help="Update an account's current balance")
    p.add_argument("name", help="Account name")
    p.add_argument("balance", type=float, help="New balance (always positive)")
    p.set_defaults(func=cmd_update)

    p = sub.add_parser("list", help="List all accounts and current balances")
    p.set_defaults(func=cmd_list)

    p = sub.add_parser("snapshot", help="Record a dated net worth snapshot from current balances")
    p.add_argument("--date", help="Date for the snapshot, YYYY-MM-DD (default: today)")
    p.set_defaults(func=cmd_snapshot)

    p = sub.add_parser("report", help="Show current net worth broken down by account")
    p.set_defaults(func=cmd_report)

    p = sub.add_parser("history", help="Show net worth for every recorded snapshot")
    p.set_defaults(func=cmd_history)

    p = sub.add_parser("chart", help="Save a PNG chart of net worth over time (requires matplotlib)")
    p.add_argument("--output", help="Output PNG path (default: net_worth_chart.png)")
    p.set_defaults(func=cmd_chart)

    return parser


def main():
    parser = build_parser()
    args = parser.parse_args()
    data = load_data(args.file)
    args.func(args, data, args.file)


if __name__ == "__main__":
    main()